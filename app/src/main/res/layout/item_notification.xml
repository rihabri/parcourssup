<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvNotifIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🔔"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/circle_light"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNotifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nouveau concours disponible"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1F2937" />

            <TextView
                android:id="@+id/tvNotifMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Le concours ENSA 2026 est ouvert"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvNotifTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Il y a 2 heures"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <View
            android:id="@+id/viewNotifDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_blue"
            android:layout_marginTop="8dp"
            android:visibility="visible" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER DÉGRADÉ BLEU/VIOLET ===== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="@drawable/bg_gradient_profil">

            <!-- Bouton Retour -->
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"
                android:padding="6dp"
                android:background="@drawable/circle_white_alpha"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true" />

            <!-- Avatar cercle -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_centerInParent="true">

                <RelativeLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_person"
                        android:background="@drawable/circle_avatar"
                        android:padding="20dp"
                        android:tint="#5B4FCF" />

                </RelativeLayout>

                <!-- Nom complet -->
                <TextView
                    android:id="@+id/tvNomProfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom Prénom"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:gravity="center" />

                <!-- Email -->
                <TextView
                    android:id="@+id/tvEmailProfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textColor="#D0D8FF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

            </LinearLayout>
        </RelativeLayout>

        <!-- ===== INFOS BADGES ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp"
            android:padding="4dp">

            <!-- Badge Ville -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_badge_white"
                android:padding="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏙️"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvVilleProfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ville"
                    android:textColor="#3D3D6B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ville"
                    android:textColor="#9999BB"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Badge Niveau -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_badge_white"
                android:padding="12dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvNiveauProfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Niveau"
                    android:textColor="#3D3D6B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Niveau scolaire"
                    android:textColor="#9999BB"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ===== SECTION : MON ESPACE ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon Espace"
            android:textColor="#3D3D6B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <!-- Card : Mes Écoles -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMesEcoles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- Icône -->
                <RelativeLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/circle_icon_blue">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_school"
                        android:tint="#FFFFFF"
                        android:layout_centerInParent="true" />

                </RelativeLayout>

                <!-- Texte -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mes Écoles"
                        android:textColor="#2D2D5E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voir mes inscriptions"
                        android:textColor="#9999BB"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Flèche -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="#C0C0DD" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SECTION : COMPTE ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compte"
            android:textColor="#3D3D6B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp" />

        <!-- Card : Déconnexion -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDeconnexion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFF0F0"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- Icône -->
                <RelativeLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/circle_icon_red">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_logout"
                        android:tint="#FFFFFF"
                        android:layout_centerInParent="true" />

                </RelativeLayout>

                <!-- Texte -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Déconnexion"
                        android:textColor="#CC2222"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quitter votre session"
                        android:textColor="#EE8888"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Flèche -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="#FFAAAA" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Spacer pour le bottom nav -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

        <!-- ===== BOTTOM NAVIGATION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:elevation="12dp"
            android:gravity="center_vertical">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:tint="#AAAACC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accueil"
                    android:textColor="#AAAACC"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Notifications -->
            <LinearLayout
                android:id="@+id/nav_notifications"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_notifications"
                    android:tint="#AAAACC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifs"
                    android:textColor="#AAAACC"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Services -->
            <LinearLayout
                android:id="@+id/nav_services"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_grid"
                    android:tint="#AAAACC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Services"
                    android:textColor="#AAAACC"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Profil (actif) -->
            <LinearLayout
                android:id="@+id/nav_profil"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_person"
                    android:tint="#5B4FCF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil"
                    android:textColor="#5B4FCF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
